rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - bio: string (optional, max 500 chars)
    //   - createdAt: timestamp (required)
    //
    // Collection: apps
    // Document ID: appId (auto-generated)
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - description: string (required, max 5000 chars)
    //   - authorId: string (required, immutable)
    //   - authorName: string (required)
    //   - authorPhoto: string (optional)
    //   - appUrl: string (optional, URL)
    //   - imageUrl: string (optional, URL)
    //   - tags: list (optional, max 10 items)
    //   - createdAt: timestamp (required, immutable)
    //   - likesCount: number (required, default 0)
    //
    // Collection: likes
    // Document ID: userId_appId
    // Fields:
    //   - userId: string (required, immutable)
    //   - appId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sheteshriharsh@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'createdAt']) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 500)) &&
             (!('photoURL' in data) || isValidUrl(data.photoURL));
    }

    function isValidApp(data) {
      return data.keys().hasAll(['name', 'description', 'authorId', 'authorName', 'createdAt', 'likesCount']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 5000 &&
             data.authorId is string &&
             data.authorName is string &&
             data.likesCount is number &&
             (!('appUrl' in data) || isValidUrl(data.appUrl)) &&
             (!('imageUrl' in data) || isValidUrl(data.imageUrl)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10));
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'appId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.userId is string &&
             data.appId is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if true; // Public profiles (no PII like email stored here)
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /apps/{appId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidApp(request.resource.data) && 
                      request.resource.data.authorId == request.auth.uid &&
                      request.resource.data.likesCount == 0;
      allow update: if (isAuthenticated() && (
                        // Author can update everything except immutable fields
                        (resource.data.authorId == request.auth.uid && isValidApp(request.resource.data) &&
                         request.resource.data.authorId == resource.data.authorId &&
                         request.resource.data.createdAt == resource.data.createdAt) ||
                        // Others can ONLY update likesCount via atomic increment
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) &&
                         math.abs(request.resource.data.likesCount - resource.data.likesCount) == 1)
                      )) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidLike(request.resource.data) &&
                      likeId == request.auth.uid + "_" + request.resource.data.appId;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // Test collection for connection check
    match /test/connection {
      allow read: if true;
    }
  }
}
